# PRAXIS Lite Environment Configuration
# Copy to .env and fill values. Never commit .env

# Render / Deployment
RENDER_API_KEY=your_render_api_key_here

# GitLab / GitHub tokens for mirroring (CI use only)
GITLAB_TOKEN=
GITHUB_TOKEN=

# App specific (example)
PRAXIS_ENV=development
PRAXIS_LOG_LEVEL=INFO
# Add more as subprojects are added (e.g. DB_URL, API keys)

# Session capture daemon (session-capture/claude+)
# Where the Go daemon writes per-session JSONL files locally.
PRAXIS_SESSIONS_LOG_DIR=~/.praxis/sessions
# DynamoDB table for the optional mirror sink. Leave empty to disable.
# Provisioned by infra/lib/sessions-table-stack.ts.
PRAXIS_SESSIONS_TABLE=praxis-sessions
# AWS region for the Dynamo sink + CDK deploy.
AWS_REGION=us-east-1
# Disable PTY allocation entirely (debug switch for ConPTY issues or batch CI).
# PRAXIS_CAPTURE_NO_PTY=0